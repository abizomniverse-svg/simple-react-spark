# =========================
# Frontend Configuration for Self-Hosting
# =========================

# Backend API URL (port where your backend server runs)
# For production, change to your server's IP or domain
REACT_APP_API_URL=http://localhost:5000

# API Proxy URL (port where backend API routes are mounted)
# This is usually the same as API_URL unless you have a reverse proxy
REACT_APP_API_PROXY=http://localhost:3000

# Example for production:
# REACT_APP_API_URL=http://192.168.1.100:5000
# REACT_APP_API_PROXY=http://192.168.1.100:3000

# Or with domain:
# REACT_APP_API_URL=https://api.yourdomain.com
# REACT_APP_API_PROXY=https://api.yourdomain.com